# Path to Google Cloud service account JSON (do not commit the real file).
# If the path contains spaces, use double quotes:
# GOOGLE_APPLICATION_CREDENTIALS="/Users/you/EW project/your-key.json"
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json

# Option A: single URL (recommended if password has special characters)
DATABASE_URL=postgresql://USER:PASSWORD@127.0.0.1:5432/DBNAME

# Option B: discrete vars (omit PGPASSWORD if using peer auth locally)
# PGHOST=127.0.0.1
# PGPORT=5432
# PGUSER=postgres
# PGPASSWORD=
# PGDATABASE=mydb
