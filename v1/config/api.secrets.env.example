# =============================================================================
# API keys & API-only secrets — copy to:  config/api.secrets.env
# That file is gitignored. Loaded automatically by function/api_config.py
# (after root .env). Values here OVERRIDE duplicate keys in .env for most keys.
#
# DATABASE_URL: do not set here for local dev. Put it in repo root `.env` only;
# api_config re-applies that value last so the app always connects to the DB
# where you ran db/schema_order.sql (avoids “relation ew_orders does not exist”).
#
# 刷新 / 轮换 Token（建议）:
#   - EW_ADMIN_TOKEN: 本地 openssl rand -hex 24 生成新串 → 写入本文件 → 重启 uvicorn；
#     旧书签 /admin?token=... 失效。
#   - GOOGLE_MAPS_API_KEY: 在 GCP「凭据」里轮转密钥或新建 Key → 更新本文件 → 重启。
# =============================================================================

# --- Session signing (login cookie) — 推荐单独随机串；未设时回退用 EW_ADMIN_TOKEN ---
EW_SESSION_SECRET=930707

# --- 自助注册 /register（首个账号始终可注册为开发者；此后需 EW_SELF_REGISTER=1）---
# 推荐写在仓库根目录 .env：加载后 api_config 会再次应用该键，避免此处出现空行 EW_SELF_REGISTER= 覆盖 .env。
# 若仅写在本文件亦可；不要留空值行。
EW_SELF_REGISTER=1
# EW_REGISTRATION_CODE=可选，与网页注册码一致时才允许注册

# --- Admin UI & 脚本：/admin?token=...、下单页 ?token= 书签 ---
EW_ADMIN_TOKEN=930707
# 下单页一键刷新旁显示的管理员称呼（默认 Simon）；书签：/f/read/order?fmt=html&token=与上相同
# 或浏览器打开 /login 输入本令牌 → Cookie 会话，侧栏显示 Simon / 退出
# EW_ADMIN_DISPLAY_NAME=Simon

# --- Google Maps Platform (Distance Matrix, Geocoding, …) ---
# Cloud Console → APIs & Services → Credentials → API key
# Or put the key alone in one line: config/google_maps_api_key.txt (gitignored)
GOOGLE_MAPS_API_KEY=AIzaSyDRYhBevokKDC4kE86QpQUq_HjzKb4b9r0
# 订单页「格式化数据（规范化邮编）」批量补全时，每条之间的毫秒延迟（缓解配额尖峰）
# EW_ORDER_MAPS_BATCH_DELAY_MS=200
# 为 1 时：不跳过「已补全」行，对全表重新请求 Google（费配额；默认 0）
# EW_ORDER_MAPS_FORCE_ENRICH=0

# --- PostgreSQL ---
# 在根目录 .env 设置 DATABASE_URL，例如：
#   本机 Homebrew：postgresql://127.0.0.1:5432/ew
#   Docker Compose（docker-compose.yml，端口 5433）：postgresql://ew:ew_dev_local@127.0.0.1:5433/ew
# 建表：psql "$DATABASE_URL" -f db/schema_order.sql

# --- Add more providers below (example placeholders) ---
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# STRIPE_SECRET_KEY=
# TWILIO_AUTH_TOKEN=
