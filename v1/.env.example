# =============================================================================
# Copy to ".env" and fill in values. Never commit ".env" (see .gitignore).
# =============================================================================

# --- Google Cloud: Sheets / Drive (service account JSON file path) ---
# Download JSON from: Cloud Console → IAM → Service accounts → Keys
# GOOGLE_APPLICATION_CREDENTIALS="/absolute/path/to/your-service-account.json"
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json

# --- All API keys (Maps, OpenAI, …): prefer dedicated file ---
# Copy config/api.secrets.env.example → config/api.secrets.env and fill in.
# Loaded by function/api_config.py (overrides duplicate names in this file).

# --- 自助注册 /register（已有首个用户后若要继续开放注册）---
# EW_SELF_REGISTER=1

# --- Postgres (sheet sync / upsert) ---
# 建表脚本：db/schema_order.sql（订单主表 ew_orders）
# Option A: single URL
DATABASE_URL=postgresql://USER:PASSWORD@127.0.0.1:5432/DBNAME

# Option B: discrete vars
# PGHOST=127.0.0.1
# PGPORT=5432
# PGUSER=postgres
# PGPASSWORD=
# PGDATABASE=mydb
